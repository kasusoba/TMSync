{
  "recipes": [
    {
      "id": "cineby-movie",
      "schemaVersion": 1,
      "name": "Cineby",
      "match": {
        "urlPattern": "www\\.cineby\\.at/movie",
        "hostnames": ["www.cineby.at"]
      },
      "mediaType": "auto",
      "video": {
        "frame": "iframe",
        "selector": "video",
        "watchedThreshold": 0.8
      },
      "extract": {
        "title": {
          "source": "meta",
          "selector": "og:title",
          "transforms": ["trim", "collapseSpaces"]
        },
        "year": {
          "source": "dom",
          "selector": ".flex-wrap > span:nth-of-type(2) > .tabular-nums",
          "transforms": ["trim", "toInt"]
        }
      }
    },
    {
      "id": "cineby-tv",
      "schemaVersion": 1,
      "name": "Cineby",
      "match": {
        "urlPattern": "www\\.cineby\\.at/tv",
        "hostnames": ["www.cineby.at"]
      },
      "mediaType": "show",
      "video": {
        "frame": "auto",
        "selector": "video",
        "watchedThreshold": 0.8
      },
      "extract": {
        "title": {
          "source": "meta",
          "selector": "og:title",
          "transforms": ["trim", "collapseSpaces"]
        },
        "season": {
          "source": "url",
          "regex": "/tv/\\d+/(\\d+)",
          "group": 1,
          "transforms": ["toInt"]
        },
        "episode": {
          "source": "url",
          "regex": "/tv/\\d+/\\d+/(\\d+)",
          "group": 1,
          "transforms": ["toInt"]
        }
      }
    },
    {
      "id": "popcornmovies-movie",
      "schemaVersion": 1,
      "name": "Popcorn Movies",
      "match": {
        "urlPattern": "popcornmovies\\.org/movie",
        "hostnames": ["popcornmovies.org"]
      },
      "mediaType": "auto",
      "video": {
        "frame": "auto",
        "selector": "video",
        "watchedThreshold": 0.8
      },
      "extract": {
        "title": {
          "source": "dom",
          "selector": "h1",
          "transforms": ["trim", "collapseSpaces"]
        },
        "year": {
          "source": "dom",
          "selector": ".hidden > span:nth-of-type(3)",
          "transforms": ["trim", "toInt"]
        }
      }
    },
    {
      "id": "popcornmovies-episode",
      "schemaVersion": 1,
      "name": "Popcorn Movies",
      "match": {
        "urlPattern": "popcornmovies\\.org/episode",
        "hostnames": ["popcornmovies.org"]
      },
      "mediaType": "auto",
      "video": {
        "frame": "auto",
        "selector": "video",
        "watchedThreshold": 0.8
      },
      "extract": {
        "title": {
          "source": "dom",
          "selector": ".tracking-tighter > a",
          "transforms": ["trim", "collapseSpaces"]
        },
        "year": {
          "source": "dom",
          "selector": ".hidden > span:nth-of-type(2)",
          "transforms": ["trim", "toInt"]
        },
        "season": {
          "source": "url",
          "regex": "(?:\\D*\\d+){0}\\D*(\\d+)",
          "group": 1,
          "transforms": ["toInt"]
        },
        "episode": {
          "source": "url",
          "regex": "(?:\\D*\\d+){1}\\D*(\\d+)",
          "group": 1,
          "transforms": ["toInt"]
        }
      }
    }
  ],
  "links": [
    {
      "id": "cineby",
      "name": "Cineby",
      "movie": "https://www.cineby.at/movie/{tmdb}",
      "tv": "https://www.cineby.at/tv/{tmdb}/{season}/{episode}"
    },
    {
      "id": "popcornmovies",
      "name": "Popcorn Movies",
      "movie": "https://popcornmovies.org/movie/{slug}",
      "tv": "https://popcornmovies.org/episode/{slug}/{season}-{episode}",
      "search": "https://popcornmovies.org/search/{title}"
    }
  ]
}
