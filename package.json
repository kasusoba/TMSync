{
  "name": "tmsync",
  "version": "0.0.0",
  "private": true,
  "description": "Passive Trakt scrobbler for movies & TV on arbitrary streaming sites.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "pnpm -F @tmsync/extension dev",
    "dev:firefox": "pnpm -F @tmsync/extension dev:firefox",
    "build": "pnpm -F @tmsync/extension build",
    "build:firefox": "pnpm -F @tmsync/extension build:firefox",
    "prepare": "pnpm -F @tmsync/extension exec wxt prepare",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "overrides": {
      "vite": "^6.3.5"
    }
  }
}
