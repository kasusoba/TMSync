# Copy to .env and fill in from your Trakt app (https://trakt.tv/oauth/applications).
# WXT exposes WXT_* vars via import.meta.env.* and inlines them into the bundle.
WXT_TRAKT_CLIENT_ID=your_trakt_client_id
WXT_TRAKT_CLIENT_SECRET=your_trakt_client_secret

# AniList (anime tracker). Create an app at https://anilist.co/settings/developer.
# AniList dropped the implicit grant, so TMSync uses the Authorization Code grant
# (client secret bundled, same as Trakt — still no backend). Register the redirect
# URI shown in TMSync's options Account section.
WXT_ANILIST_CLIENT_ID=your_anilist_client_id
WXT_ANILIST_CLIENT_SECRET=your_anilist_client_secret

# Firefox needs a SEPARATE AniList app: AniList permits only one redirect URL per
# app, and Firefox's launchWebAuthFlow redirect (…extensions.allizom.org) differs
# from Chrome's (…chromiumapp.org). Register a second app with the Firefox
# redirect URL and set it here. Leave blank to fall back to the shared app.
WXT_ANILIST_CLIENT_ID_FIREFOX=
WXT_ANILIST_CLIENT_SECRET_FIREFOX=

# Optional: where the shared recipe list is fetched from, and the repo to
# contribute to. Defaults point at the project repo on raw.githubusercontent.com.
# WXT_RECIPES_URL=https://raw.githubusercontent.com/kasusoba/TMSync/main/recipes/index.json
# WXT_RECIPES_REPO=https://github.com/kasusoba/TMSync
