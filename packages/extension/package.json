{
  "name": "@tmsync/extension",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "TMSync WebExtension (WXT + Preact).",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "wxt build && playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@medv/finder": "^4.0.2",
    "@tmsync/shared": "workspace:*",
    "@webext-core/messaging": "^3.0.2",
    "preact": "^10.25.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@preact/preset-vite": "^2.10.1",
    "happy-dom": "^15.11.7",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4",
    "wxt": "^0.20.6"
  }
}
